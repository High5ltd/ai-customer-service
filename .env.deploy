# Chỉ các biến nên cấu hình trên K8s (Secret / ConfigMap).
# Mọi setting khác có default trong RAG/config/settings.py — chỉ thêm khi bạn cần override.
#
# Gợi ý: OPENAI_API_KEY, POSTGRES_PASSWORD, REDIS_URL (nếu có mật khẩu), CHATWOOT_BOT_TOKEN → Secret.
#        POSTGRES_HOST, POSTGRES_DB, POSTGRES_USER, QDRANT_*, CORS_ORIGINS, CHATWOOT_BASE_URL → ConfigMap (hoặc Secret nếu policy yêu cầu).

# --- Bắt buộc (không có default trong code) ---
OPENAI_API_KEY=

# --- PostgreSQL (default code trỏ localhost — bắt buộc đổi trong cluster) ---
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- Qdrant ---
QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# --- Redis ---
REDIS_URL=

# --- Bắt buộc khi frontend (Vercel) gọi API: liệt kê origin được phép, cách nhau bởi dấu phẩy ---
CORS_ORIGINS=

# --- Chatwoot Agent Bot (POST /webhooks/chatwoot — cần nếu bot gửi reply qua API) ---
CHATWOOT_BASE_URL=
CHATWOOT_BOT_TOKEN=

# --- App (port khớp Service / containerPort / probes) ---
APP_PORT=8000

# === Chỉ thêm khi cần đổi so với default ===
# LOG_LEVEL=INFO
# UPLOAD_DIR=./uploads
