# Biến nên cấu hình trên K8s (Secret / ConfigMap).
# Pod khởi động không cần Postgres / Qdrant / Redis; chỉ các route dùng chúng mới trả 503 nếu infra lỗi.
#
# Gợi ý: OPENAI_API_KEY, POSTGRES_PASSWORD, REDIS_URL (nếu có mật khẩu), CHATWOOT_BOT_TOKEN → Secret.
#        Các biến còn lại (trừ secret) → ConfigMap tùy policy.

# --- Tối thiểu cho webhook Chatwoot + OpenAI (POST /webhooks/chatwoot) ---
OPENAI_API_KEY=
CHATWOOT_BASE_URL=
CHATWOOT_BOT_TOKEN=
# Nếu có frontend gọi API trực tiếp:
CORS_ORIGINS=

# --- Chỉ cần khi dùng API documents / chat RAG (hoặc /health/ready mong đủ dependency) ---
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_COLLECTION=documents
REDIS_URL=

# --- App (port khớp Service / containerPort / probes) ---
APP_PORT=8000

# === Chỉ thêm khi cần đổi so với default ===
# LOG_LEVEL=INFO
# UPLOAD_DIR=./uploads
