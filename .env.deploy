# Chỉ các biến nên cấu hình trên K8s (Secret / ConfigMap).
# Mọi setting khác có default trong RAG/config/settings.py — chỉ thêm khi bạn cần override.
#
# Gợi ý: OPENAI_API_KEY, POSTGRES_PASSWORD, REDIS_URL (nếu có mật khẩu) → Secret.
#        POSTGRES_HOST, POSTGRES_DB, POSTGRES_USER, QDRANT_*, CORS_ORIGINS → ConfigMap (hoặc Secret nếu policy yêu cầu).

# --- Bắt buộc (không có default trong code) ---
OPENAI_API_KEY=

# --- PostgreSQL (default code trỏ localhost — bắt buộc đổi trong cluster) ---
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- Qdrant ---
QDRANT_HOST=
QDRANT_PORT=6333

# --- Redis ---
REDIS_URL=

# --- Bắt buộc khi frontend (Vercel) gọi API: liệt kê origin được phép, cách nhau bởi dấu phẩy ---
CORS_ORIGINS=

# === Không cần khai trong K8s trừ khi bạn muốn đổi so với default ===
# QDRANT_COLLECTION=documents
# CHATWOOT_BASE_URL=
# CHATWOOT_BOT_TOKEN=
# METRICS_ENABLED=true
# LOG_LEVEL=INFO
# APP_PORT=8000
# UPLOAD_DIR=./uploads
