# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400

# ─── App ──────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Prometheus exposition (GET /metrics). Set false to disable.
METRICS_ENABLED=true

# ─── Chatwoot Agent Bot (optional) ────────────────────────────────────────────
# Webhook path on this app: POST /webhooks/chatwoot  →  register as https://<ngrok>/webhooks/chatwoot
CHATWOOT_BASE_URL=https://your-chatwoot.example.com
CHATWOOT_BOT_TOKEN=

# ─── RAG settings ─────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.4
