#!/usr/bin/env bash
# pre-commit hook — runs automatically before every commit.
# Install: bash git-hook/install.sh

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
RESET='\033[0m'

pass() { echo -e "${GREEN}✔ $1${RESET}"; }
fail() { echo -e "${RED}✘ $1${RESET}"; exit 1; }
section() { echo -e "${CYAN}▶ $1${RESET}"; }

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
STAGED_FE=$(git diff --cached --name-only --diff-filter=ACM | grep '^frontend/.*\.\(ts\|tsx\)$' || true)

# ── Python ────────────────────────────────────────────────────────────────────
if [ -n "$STAGED_PY" ]; then
  section "ruff lint"
  # shellcheck disable=SC2086
  poetry run ruff check $STAGED_PY || fail "ruff lint failed — run: poetry run ruff check --fix"

  section "ruff format"
  # shellcheck disable=SC2086
  poetry run ruff format --check $STAGED_PY || fail "ruff format failed — run: poetry run ruff format"

  pass "Python checks passed"
fi

# ── TypeScript ────────────────────────────────────────────────────────────────
if [ -n "$STAGED_FE" ]; then
  section "tsc type check"
  (cd frontend && pnpm tsc --noEmit) || fail "TypeScript errors found — fix them before committing"

  pass "TypeScript checks passed"
fi
